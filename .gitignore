# Dependencies
node_modules/

# Build artefacts
dist/
*.tsbuildinfo
.place/

# Test / coverage
coverage/
.vitest-cache/

# Local databases (dev sync-server, etc.)
*.db

# Scratch — local-only working notes + temp dev scripts.
# Kept on disk for the author; never committed.
/tmp/
/.tmp-*.sh
/research-dx-painpoints.md
/research-file-split-plan.md
/research-hmr-codesplit.md
/research-img-vt-cli.md
/research-tanstack-comparison.md

# OS
.DS_Store
Thumbs.db
*:Zone.Identifier

# Editor
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*
bun-debug.log*

# Claude Code: keep agents committed; ignore local-only settings +
# machine-specific dev tooling (absolute WSL paths, dev-only secrets)
# + per-session runtime artefacts that don't belong in history.
.claude/settings.local.json
.claude/launch.json
.claude/dev*.sh
.claude/scheduled_tasks.lock

# Env
.env
.env.local
.env.*.local

# Lighthouse user-data dirs — Chrome/Chromium spawned by `lighthouse`
# tries to mkdir its cache under a WSL-path-mangled prefix when run
# against `localhost:5175` in the docs preview; the resulting dir
# names contain literal backslashes and "undefined" segments. They're
# transient and should never be committed.
**/lighthouse.*
**/undefined:/

# bun pm pack artefacts — local tarballs from the publish smoke test
# (`scripts/smoke-test-publish.sh`). They're regenerated on demand
# and should never enter history.
systems/*/place-*.tgz
