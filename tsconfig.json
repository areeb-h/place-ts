{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "@place-ts/component",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noEmit": true,
    "resolveJsonModule": true,

    "paths": {
      "@place-ts/reactivity": ["./systems/reactivity/src/index.ts"],
      "@place-ts/reactivity/motion": ["./systems/reactivity/src/motion/index.ts"],
      "@place-ts/reactivity/effects": ["./systems/reactivity/src/effects.ts"],
      "@place-ts/capability": ["./systems/capability/src/index.ts"],
      "@place-ts/routing": ["./systems/routing/src/index.ts"],
      "@place-ts/component": ["./systems/component/src/index.ts"],
      "@place-ts/component/client": ["./systems/component/src/client.ts"],
      "@place-ts/component/server": ["./systems/component/src/server.ts"],
      "@place-ts/component/islands": ["./systems/component/src/islands.ts"],
      "@place-ts/component/build": ["./systems/component/src/build.ts"],
      "@place-ts/component/internal": ["./systems/component/src/internal.ts"],
      "@place-ts/component/auto-import-plugin": ["./systems/component/src/auto-import-plugin.ts"],
      "@place-ts/component/jsx-runtime": ["./systems/component/src/jsx-runtime.ts"],
      "@place-ts/component/jsx-dev-runtime": ["./systems/component/src/jsx-runtime.ts"],
      "@place-ts/component/tailwind": ["./systems/component/src/tailwind.ts"],
      "@place-ts/data": ["./systems/data/src/index.ts"],
      "@place-ts/persistence": ["./systems/persistence/src/index.ts"],
      "@place-ts/search": ["./systems/search/src/index.ts"],
      "@place-ts/security": ["./systems/security/src/index.ts"],
      "@place-ts/design": ["./systems/design/src/index.ts"],
      "@place-ts/devtools": ["./systems/devtools/src/index.ts"]
    }
  },
  "include": ["systems/**/*.ts", "tests/**/*.ts", "benchmarks/**/*.ts", "*.ts"],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/node_modules",
    "examples/**",
    "systems/component/**",
    "systems/design/**",
    "systems/devtools/**",
    "systems/persistence/**",
    "systems/routing/**",
    "systems/security/**"
  ]
}
