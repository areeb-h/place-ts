{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "@place/component",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noEmit": true,
    "resolveJsonModule": true,

    "paths": {
      "@place/reactivity": ["./systems/reactivity/src/index.ts"],
      "@place/reactivity/motion": ["./systems/reactivity/src/motion/index.ts"],
      "@place/reactivity/effects": ["./systems/reactivity/src/effects.ts"],
      "@place/capability": ["./systems/capability/src/index.ts"],
      "@place/routing": ["./systems/routing/src/index.ts"],
      "@place/component": ["./systems/component/src/index.ts"],
      "@place/component/jsx-runtime": ["./systems/component/src/jsx-runtime.ts"],
      "@place/component/jsx-dev-runtime": ["./systems/component/src/jsx-runtime.ts"],
      "@place/component/tailwind": ["./systems/component/src/tailwind.ts"],
      "@place/data": ["./systems/data/src/index.ts"],
      "@place/persistence": ["./systems/persistence/src/index.ts"],
      "@place/search": ["./systems/search/src/index.ts"],
      "@place/security": ["./systems/security/src/index.ts"],
      "@place/design": ["./systems/design/src/index.ts"]
    }
  },
  "include": ["systems/**/*.ts", "tests/**/*.ts", "benchmarks/**/*.ts", "*.ts"],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/node_modules",
    "examples/**",
    "systems/component/**",
    "systems/design/**",
    "systems/persistence/**",
    "systems/routing/**",
    "systems/security/**"
  ]
}
