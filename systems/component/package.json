{
  "name": "@place-ts/component",
  "version": "0.10.9",
  "type": "module",
  "description": "Component system — rendering layer on top of @place-ts/reactivity. JSX-shape via TS automatic runtime (per ADR 0002).",
  "keywords": [
    "place",
    "place-ts",
    "component",
    "jsx",
    "ssr",
    "islands",
    "view"
  ],
  "homepage": "https://github.com/areeb-h/place-ts/tree/main/systems/component#readme",
  "bugs": {
    "url": "https://github.com/areeb-h/place-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/areeb-h/place-ts.git",
    "directory": "systems/component"
  },
  "license": "MIT",
  "author": "Areeb",
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./src/preload.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./islands": "./src/islands.ts",
    "./build": "./src/build.ts",
    "./internal": "./src/internal.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts",
    "./tailwind": "./src/tailwind.ts",
    "./preload": "./src/preload.ts",
    "./auto-imports": "./src/auto-imports.d.ts",
    "./auto-import-plugin": "./src/auto-import-plugin.ts",
    "./adapters/node": "./src/adapters/node.ts",
    "./adapters/cloudflare": "./src/adapters/cloudflare.ts",
    "./adapters/vercel": "./src/adapters/vercel.ts",
    "./adapters/deno": "./src/adapters/deno.ts"
  },
  "files": [
    "src",
    "README.md",
    "docs",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@place-ts/capability": "workspace:*",
    "@place-ts/reactivity": "workspace:*",
    "@place-ts/routing": "workspace:*",
    "@place-ts/security": "workspace:*",
    "devalue": "^5.8.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@tailwindcss/node": "^4.2.4",
    "@tailwindcss/oxide": "^4.2.4",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.2.4"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/node": {
      "optional": true
    },
    "@tailwindcss/oxide": {
      "optional": true
    },
    "sharp": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  }
}
